  "layout_patterns": {
    "sidebar-left-fixed": {
      "description": "左侧固定侧边栏 + 右侧内容区",
      "structure": "aside(固定) + main(滚动)",
      "use_for": "admin dashboard, internal tools",
      "reference": "https://ant.design/components/layout"
    },
    "sidebar-left-collapsible": {
      "description": "左侧可折叠侧边栏 + 右侧内容区",
      "structure": "aside(64px/220px 切换) + main",
      "use_for": "SaaS, multi-module apps",
      "reference": "https://material.io/components/navigation-drawer"
    },
    "topnav-fixed": {
      "description": "顶部固定导航栏 + 下方内容区",
      "structure": "header(固定) + main",
      "use_for": "marketing pages, simple apps",
      "reference": "https://developer.apple.com/design/human-interface-guidelines/navigation-bars"
    },
    "topnav-with-categories": {
      "description": "顶部导航 + 分类标签栏 + 内容区",
      "structure": "header + tab-bar + main",
      "use_for": "ecommerce, content platforms",
      "reference": "https://m3.material.io/components/top-app-bar"
    },
    "sidebar-left-with-progress": {
      "description": "左侧带进度追踪的侧边栏",
      "structure": "aside(带进度条) + main",
      "use_for": "learning platforms, wizards",
      "reference": "https://www.figma.com/community/file/steps-progress-bar"
    },
    "feed-center": {
      "description": "居中信息流布局（类 Twitter/微博）",
      "structure": "sidebar(左) + feed(中) + aside(右)",
      "use_for": "social media, content feeds",
      "reference": "https://twitter.com 的三栏布局"
    },
    "grid-dashboard": {
      "description": "网格化仪表盘布局",
      "structure": "CSS Grid / Flex 多列卡片",
      "use_for": "data dashboards, monitoring",
      "reference": "https://grafana.com 的面板布局"
    },
    "split-screen": {
      "description": "左右分屏（左侧导航/右侧内容）",
