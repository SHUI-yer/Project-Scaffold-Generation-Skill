      },
      "P2_classic": {
        "label": "经典稳重方案",
        "profiles": ["slate-corporate", "arctic-white", "sakura-pink"],
        "design_systems": ["flat-design", "neomorphism"],
        "features": ["中性配色", "标准间距", "传统布局"],
        "reason": "保守安全，适合内部工具或不喜欢花哨的用户"
      }
    },
    "must_include_when_premium": {
      "gradient_effects": "按钮和导航栏使用渐变色（如 linear-gradient(135deg, primary, secondary)）",
      "glassmorphism": "弹窗/卡片使用 backdrop-filter: blur(12px) + rgba背景",
      "custom_font": "引入 Google Fonts 高质量字体（Inter / Plus Jakarta Sans / Outfit / DM Sans）",
      "large_border_radius": "按钮/卡片/输入框使用 10-16px 圆角，避免 4px 小圆角",
      "micro_interactions": "按钮 hover 缩放/变色、页面切换过渡、loading 骨架屏",
      "dark_mode_base": "优先使用深色模式作为默认主题（背景色 #0f0f23 或 #121212）",
      "shadows_depth": "使用多层 box-shadow 营造深度感（如 shadow_sm + shadow_md + shadow_lg 组合）"
    }
